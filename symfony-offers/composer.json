{
  "name": "umk-lectures-paw-2026-lab/symfony-offers",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "symfony/framework-bundle": "^7.3",
    "symfony/http-client": "^7.3",
    "symfony/dotenv": "^7.3",
    "symfony/runtime": "^7.3",
    "symfony/yaml": "^7.3"
  },
  "require-dev": {
    "symfony/phpunit-bridge": "^7.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  }
}
